<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/ui_bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_pet_icon_circle"
                android:layout_marginEnd="12dp">
                <ImageView
                    android:id="@+id/imgActivePetPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_pet_preview"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/textName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/ui_text_title"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/label_level"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/ui_sky_dark"
                    android:background="@drawable/bg_level_badge"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"/>
            </LinearLayout>
                
            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/ui_text_mute"
                android:alpha="0.5"/>
        </LinearLayout>

        <!-- Stats Bars -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <!-- Energy -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <ImageView 
                    android:layout_width="16dp" 
                    android:layout_height="16dp" 
                    android:src="@android:drawable/ic_lock_idle_charging"
                    app:tint="@color/ui_text_mute"/>
                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_energy"
                    android:textSize="12sp"
                    android:textColor="@color/ui_text_mute"
                    android:layout_marginStart="8dp"/>
                <ProgressBar
                    android:id="@+id/progressEnergy"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progressDrawable="@drawable/progress_energy"
                    android:progress="70"
                    android:max="100"/>
            </LinearLayout>

            <!-- Mood -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <ImageView 
                    android:layout_width="16dp" 
                    android:layout_height="16dp" 
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="@color/ui_text_mute"/>
                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_mood"
                    android:textSize="12sp"
                    android:textColor="@color/ui_text_mute"
                    android:layout_marginStart="8dp"/>
                <ProgressBar
                    android:id="@+id/progressMood"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progressDrawable="@drawable/progress_mood"
                    android:progress="50"
                    android:max="100"/>
            </LinearLayout>

            <!-- Hunger -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView 
                    android:layout_width="16dp" 
                    android:layout_height="16dp" 
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="@color/ui_text_mute"/>
                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_hunger"
                    android:textSize="12sp"
                    android:textColor="@color/ui_text_mute"
                    android:layout_marginStart="8dp"/>
                <ProgressBar
                    android:id="@+id/progressHunger"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progressDrawable="@drawable/progress_hunger"
                    android:progress="30"
                    android:max="100"/>
            </LinearLayout>
        </LinearLayout>
        
        <!-- Action Button -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/action_pause"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_btn_primary"
            app:backgroundTint="@null"
            android:elevation="4dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
