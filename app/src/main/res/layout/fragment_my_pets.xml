<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_stage_gradient"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_my_pets_cn"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/ui_text_title"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/textEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="暂无桌宠，快去商店领养吧！"
        android:gravity="center"
        android:textSize="18sp"
        android:textColor="@color/ui_text_mute"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerActivePets"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp"/>

</LinearLayout>
