<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_stage_gradient"
    android:paddingStart="@dimen/page_padding"
    android:paddingEnd="@dimen/page_padding"
    android:paddingTop="@dimen/page_padding_top">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_my_pets_cn"
        style="@style/TextAppearance.App.PageTitle"
        android:letterSpacing="0.02"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/textEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="暂无桌宠，快去商店领养吧"
        android:gravity="center"
        android:textSize="@dimen/body_text"
        android:textColor="@color/ui_text_mute"
        android:lineSpacingMultiplier="1.3"
        android:padding="32dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerActivePets"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/list_bottom_padding"
        android:paddingTop="4dp"/>
</LinearLayout>
