<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_pixel_house_room"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#E8F5E6D3"
        app:navigationIcon="@drawable/ic_back"
        app:titleTextColor="@color/ui_text_title"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="0dp"
            android:paddingTop="0dp">

            <FrameLayout
                android:id="@+id/layoutRoomContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="0dp"
                android:clipChildren="true"
                android:clipToPadding="true">

                <View
                    android:layout_width="160dp"
                    android:layout_height="80dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_pixel_house_window"/>

                <View
                    android:layout_width="120dp"
                    android:layout_height="40dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="60dp"
                    android:background="@drawable/bg_pixel_house_rug"/>

                <View
                    android:layout_width="80dp"
                    android:layout_height="48dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="40dp"
                    android:layout_marginBottom="50dp"
                    android:background="@drawable/bg_pixel_pet_bed"/>

                <FrameLayout
                    android:id="@+id/layoutDecorLayer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="true"
                    android:clipToPadding="true" />

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">

                    <View
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_stage_platform"/>
                </FrameLayout>

                <com.pixelpet.pet.view.PetView
                    android:id="@+id/petView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:clipChildren="false"/>

                <LinearLayout
                    android:id="@+id/layoutStatusPanel"
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_status_overlay"
                    android:orientation="vertical"
                    android:gravity="start">

                    <ImageButton
                        android:id="@+id/btnToggleStatus"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="end"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_pixel_list"
                        android:contentDescription="toggle_status"
                        android:scaleType="centerInside"
                        android:visibility="gone"
                        app:tint="@color/ui_text_mute"/>

                    <LinearLayout
                        android:id="@+id/layoutStatusContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textPetName"
                            style="@style/PixelText.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                        <TextView
                            android:id="@+id/textLevelMini"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="LV.1 新手"
                            android:textColor="@color/ui_text_title"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/progressLevelXp"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="6dp"
                            android:max="100"
                            android:progress="0"
                            android:progressDrawable="@drawable/progress_energy" />

                        <TextView
                            android:id="@+id/textXpMini"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="经验 0%"
                            android:textColor="@color/ui_text_mute"
                            android:textSize="10sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_size"
                                android:textColor="@color/ui_text_mute"
                                android:textSize="11sp"
                                android:layout_marginEnd="6dp"/>
                            <SeekBar
                                android:id="@+id/seekInstanceScale"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="50"/>
                            <TextView
                                android:id="@+id/textInstanceScaleValue"
                                android:layout_width="40dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:text="1.0x"
                                android:textColor="@color/ui_text_main"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="6dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_energy"
                                    android:contentDescription="@null"/>
                                <ProgressBar
                                    android:id="@+id/progressEnergy"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="0dp"
                                    android:layout_height="4dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="8dp"
                                    android:progressDrawable="@drawable/progress_energy"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_mood"
                                    android:contentDescription="@null"/>
                                <ProgressBar
                                    android:id="@+id/progressMood"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="0dp"
                                    android:layout_height="4dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="8dp"
                                    android:progressDrawable="@drawable/progress_mood"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_hunger"
                                    android:contentDescription="@null"/>
                                <ProgressBar
                                    android:id="@+id/progressHunger"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="0dp"
                                    android:layout_height="4dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="8dp"
                                    android:progressDrawable="@drawable/progress_hunger"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgEasterEggCrown"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="16dp"
                    android:alpha="0.8"
                    android:visibility="gone"
                    android:contentDescription="Mystery Crown"/>

                <FrameLayout
                    android:id="@+id/layoutConsoleDock"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageButton
                        android:id="@+id/btnToggleConsole"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_pet_icon_circle"
                        android:src="@drawable/ic_nav_settings"
                        android:contentDescription="toggle_console"
                        android:scaleType="centerInside"
                        app:tint="@color/ui_text_main"/>

                    <LinearLayout
                        android:id="@+id/layoutConsoleContent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:layout_marginEnd="12dp"
                        android:orientation="vertical"
                        android:gravity="center_horizontal|center_vertical"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@null">

                        <Button
                            android:id="@+id/btnToggleSummon"
                            android:layout_width="@dimen/edge_button_size"
                            android:layout_height="@dimen/edge_button_size"
                            android:text="@string/action_summon"
                            android:textSize="@dimen/edge_button_text"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_pet_icon_circle"
                            android:textColor="@color/ui_text_title"/>

                        <Button
                            android:id="@+id/btnRoomFeed"
                            android:layout_width="@dimen/edge_button_size"
                            android:layout_height="@dimen/edge_button_size"
                            android:layout_marginTop="10dp"
                            android:text="@string/action_feed"
                            android:textSize="@dimen/edge_button_text"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_pet_icon_circle"
                            android:textColor="@color/ui_text_main"/>

                        <Button
                            android:id="@+id/btnSleep"
                            android:layout_width="@dimen/edge_button_size"
                            android:layout_height="@dimen/edge_button_size"
                            android:layout_marginTop="10dp"
                            android:text="睡觉"
                            android:textSize="@dimen/edge_button_text"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_pet_icon_circle"
                            android:textColor="@color/ui_text_main"/>

                        <Button
                            android:id="@+id/btnGreet"
                            android:layout_width="@dimen/edge_button_size"
                            android:layout_height="@dimen/edge_button_size"
                            android:layout_marginTop="10dp"
                            android:text="打招呼"
                            android:textSize="@dimen/edge_button_text"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_pet_icon_circle"
                            android:textColor="@color/ui_text_main"/>

                        <Button
                            android:id="@+id/btnSing"
                            android:layout_width="@dimen/edge_button_size"
                            android:layout_height="@dimen/edge_button_size"
                            android:layout_marginTop="10dp"
                            android:text="唱歌"
                            android:textSize="@dimen/edge_button_text"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_pet_icon_circle"
                            android:textColor="@color/ui_text_main"/>

                        <Button
                            android:id="@+id/btnViolin"
                            android:layout_width="@dimen/edge_button_size"
                            android:layout_height="@dimen/edge_button_size"
                            android:layout_marginTop="10dp"
                            android:text="小提琴"
                            android:textSize="@dimen/edge_button_text"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_pet_icon_circle"
                            android:textColor="@color/ui_text_main"/>

                        <Button
                            android:id="@+id/btnPiano"
                            android:layout_width="@dimen/edge_button_size"
                            android:layout_height="@dimen/edge_button_size"
                            android:layout_marginTop="10dp"
                            android:text="钢琴"
                            android:textSize="@dimen/edge_button_text"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_pet_icon_circle"
                            android:textColor="@color/ui_text_main"/>

                        <Button
                            android:id="@+id/btnDecorAdd"
                            android:layout_width="@dimen/edge_button_size"
                            android:layout_height="@dimen/edge_button_size"
                            android:layout_marginTop="10dp"
                            android:text="装饰+"
                            android:textSize="@dimen/edge_button_text"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_pet_icon_circle"
                            android:textColor="@color/ui_text_main"/>

                        <Button
                            android:id="@+id/btnConsoleMore"
                            android:layout_width="@dimen/edge_button_size"
                            android:layout_height="@dimen/edge_button_size"
                            android:layout_marginTop="10dp"
                            android:text="更多"
                            android:textSize="@dimen/edge_button_text"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_pet_icon_circle"
                            android:textColor="@color/ui_text_main"/>

                        <LinearLayout
                            android:id="@+id/layoutConsoleAdvanced"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:visibility="gone">

                            <Button
                                android:id="@+id/btnRoomRename"
                                android:layout_width="@dimen/edge_button_size"
                                android:layout_height="@dimen/edge_button_size"
                                android:text="@string/action_rename"
                                android:textSize="@dimen/edge_button_text"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_pet_icon_circle"
                                android:textColor="@color/ui_text_main"/>

                            <Button
                                android:id="@+id/btnRoomDelete"
                                android:layout_width="@dimen/edge_button_size"
                                android:layout_height="@dimen/edge_button_size"
                                android:layout_marginTop="10dp"
                                android:text="@string/action_delete"
                                android:textSize="@dimen/edge_button_text"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_pet_icon_circle"
                                android:textColor="@color/ui_rose"/>

                            <Button
                                android:id="@+id/btnDecorClear"
                                android:layout_width="@dimen/edge_button_size"
                                android:layout_height="@dimen/edge_button_size"
                                android:layout_marginTop="10dp"
                                android:text="清空"
                                android:textSize="@dimen/edge_button_text"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_pet_icon_circle"
                                android:textColor="@color/ui_rose"/>
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>
            </FrameLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
