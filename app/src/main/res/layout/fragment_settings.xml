<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_stage_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/page_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_scale"
            style="@style/TextAppearance.App.SectionTitle"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_control_card"
            android:padding="@dimen/card_padding_small">

            <SeekBar
                android:id="@+id/seekScale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progressTint="@color/colorPrimary"
                android:thumbTint="@color/colorPrimary" />

            <TextView
                android:id="@+id/textScaleValue"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="1.0x"
                android:textSize="@dimen/body_text"
                android:textColor="@color/ui_text_main"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_alpha"
            style="@style/TextAppearance.App.SectionTitle"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_control_card"
            android:padding="@dimen/card_padding_small">

            <SeekBar
                android:id="@+id/seekAlpha"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="10"
                android:progressTint="@color/colorPrimary"
                android:thumbTint="@color/colorPrimary" />

            <TextView
                android:id="@+id/textAlphaValue"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="100%"
                android:textSize="@dimen/body_text"
                android:textColor="@color/ui_text_main"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_control_card"
            android:padding="@dimen/card_padding_small"
            android:layout_marginBottom="32dp"
            android:orientation="vertical">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchVerticalMove"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_vertical_move"
                android:textSize="@dimen/body_text"
                android:textColor="@color/ui_text_main"
                app:thumbTint="@color/ui_bg_card"
                app:trackTint="@color/ui_green_light" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_drift"
            style="@style/TextAppearance.App.SectionTitle"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_control_card"
            android:padding="@dimen/card_padding_small"
            android:layout_marginBottom="32dp"
            android:orientation="vertical">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchDrift"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_drift_enable"
                android:textSize="@dimen/body_text"
                android:textColor="@color/ui_text_main"
                app:thumbTint="@color/ui_bg_card"
                app:trackTint="@color/ui_green_light"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_drift_speed"
                style="@style/TextAppearance.App.Subtitle"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <SeekBar
                    android:id="@+id/seekDriftSpeed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progressTint="@color/colorPrimary"
                    android:thumbTint="@color/colorPrimary" />

                <TextView
                    android:id="@+id/textDriftSpeedValue"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="50"
                    android:textSize="@dimen/body_text"
                    android:textColor="@color/ui_text_main"
                    android:layout_marginStart="16dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_assets_title"
            style="@style/TextAppearance.App.SectionTitle"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_control_card"
            android:padding="@dimen/card_padding_small"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/btnImportImage"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/settings_import_image"
                android:textSize="@dimen/body_text"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_primary"
                app:backgroundTint="@null"
                android:textColor="@android:color/white"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnManageAssets"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/settings_manage_assets"
                android:textSize="@dimen/body_text"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_secondary"
                app:backgroundTint="@null"
                android:textColor="@color/ui_text_main"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnImportPet"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/settings_import_pet"
                android:textSize="@dimen/body_text"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_secondary"
                app:backgroundTint="@null"
                android:textColor="@color/ui_text_main" />

        </LinearLayout>

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="16dp"
            android:text="@string/action_reset_defaults"
            android:textSize="@dimen/body_text"
            android:textAllCaps="false"
            android:background="@drawable/bg_btn_secondary"
            app:backgroundTint="@null"
            android:textColor="@color/ui_text_main" />

    </LinearLayout>
</ScrollView>
