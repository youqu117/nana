<?xml version="1.0" encoding="utf-8"?>
<!-- Pixel-style pet bed/cushion -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#D4A574"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#E8C9A0"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</layer-list>
