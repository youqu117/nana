<?xml version="1.0" encoding="utf-8"?>
<!-- Pixel window with frame -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Frame (dark wood) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#5D4E37"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
    <!-- Glass (light blue sky) -->
    <item
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#87CEEB"
                android:endColor="#B0E0E6"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>
</layer-list>
